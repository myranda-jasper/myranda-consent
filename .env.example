# Copy this file to .env.local and fill in your values.

# Privy App ID — public, client-side identifier. Get it from https://dashboard.privy.io
NEXT_PUBLIC_PRIVY_APP_ID=

# Optional — Walrus testnet endpoints used by the server-side proxy.
# Sensible testnet defaults are baked into the code, so these are only needed
# if you want to point at a different publisher/aggregator.
# WALRUS_PUBLISHER_URL=https://publisher.walrus-testnet.walrus.space
# WALRUS_AGGREGATOR_URL=https://aggregator.walrus-testnet.walrus.space
# WALRUS_EPOCHS=5
